{
  "compilerOptions": {
    "target": "ES2015",
    "module": "CommonJS",
   "moduleResolution": "node10",
"ignoreDeprecations": "6.0",
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "example"]
}